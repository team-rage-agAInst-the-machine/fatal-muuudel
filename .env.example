# Postgres — usado pelo Prisma (CLI via prisma.config.ts) e pelo client em runtime.
# Credenciais batem com docker-compose.yml — basta rodar `docker compose up -d`.
DATABASE_URL="postgresql://fatal:muuudel@localhost:5432/fatal_muuudel?schema=public"

# NextAuth / Auth.js v5
# Gere um secret com:  npx auth secret
AUTH_SECRET=""
# Em produção defina a URL pública (Vercel preenche AUTH_URL automaticamente).
# AUTH_URL="http://localhost:3000"

# S3 — fotos das vacas
# Em produção, remova S3_ENDPOINT e use credenciais reais da AWS.
S3_BUCKET_NAME="fatal-muuudel"
S3_REGION="us-east-1"
S3_ENDPOINT="http://localhost:4566"
S3_ACCESS_KEY_ID="test"
S3_SECRET_ACCESS_KEY="test"
