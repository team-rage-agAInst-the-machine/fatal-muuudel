# Postgres — usado pelo Prisma (CLI via prisma.config.ts) e pelo client em runtime.
# Credenciais batem com docker-compose.yml — basta rodar `docker compose up -d`.
DATABASE_URL="postgresql://fatal:muuudel@localhost:5432/fatal_muuudel?schema=public"

# Google AI Studio — chat interestelar com a vaca abduzida
# Obtenha em: https://aistudio.google.com/app/api-keys
# Se ausente, o chat usa respostas mockadas automaticamente.
GOOGLE_AI_API_KEY=""

# Pexels API — fotos reais de vacas no seed
# Obtenha em: https://www.pexels.com/api/
# Se ausente, o seed usa fotos de fallback do Pexels (sem busca dinâmica).
PEXELS_API_KEY=""

# NextAuth / Auth.js v5
# Gere um secret com:  npx auth secret
AUTH_SECRET=""
# Em produção defina a URL pública (Vercel preenche AUTH_URL automaticamente).
# AUTH_URL="http://localhost:3000"

# AWS S3 — upload de foto de perfil do ET (deixe vazio para usar armazenamento local em dev)
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# AWS_S3_PUBLIC_URL=""   ← opcional: URL pública customizada (CloudFront, etc.)
