// Fatal Muuudel — Tinder for ETs picking cows to abduct.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// NextAuth (Auth.js) tables — required by @auth/prisma-adapter.
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Domain models
// ---------------------------------------------------------------------------

// A User in Auth.js terms is an Alien/ET pilot here.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  // ET-specific profile
  callsign       String?  @unique
  homePlanet     String?
  shipModel      String?

  // Dados biológicos e afiliação galáctica
  species        String?
  locomotion     String?
  skinColor      String?
  eyeCount       Int?
  iq             Int?
  towelStatus    String?
  forceSensitive Boolean?
  starfleetRank  String?

  createdAt DateTime @default(now())

  accounts   Account[]
  sessions   Session[]
  swipes     Swipe[]
  abductions Abduction[]
  missions   MissionConfig[]
}

model MissionConfig {
  id               String   @id @default(cuid())
  alienId          String
  alien            User     @relation(fields: [alienId], references: [id], onDelete: Cascade)
  name             String
  isActive         Boolean  @default(false)
  abductionStyle   String? // "stealth" | "científico" | "flashy" | "casual"
  objetivoDaMissao String? // "pesquisa" | "troféu" | "companhia" | "experimento"
  temperamento     String? // "paciente" | "agitado" | "curioso" | "dominante"
  signoGalactico   String?
  mooPreference    Int?    // preferência de mugido 0-10
  maxCargoKg       Int?    // capacidade de carga da nave em kg
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([alienId])
}

enum CowProtectionLevel {
  EXTRAVIADA // se perdeu do rebanho — qualquer ET pode abduzi-la
  CAMPESTRE // vaquinha comum do pasto
  VEDETE // vedete do capim
  ELITE // raça fina, campeã regional
  SAGRADA // patrimônio bovino nacional — requer toalha
  DIVINA // reencarnação bovina suprema — requer toalha
}

model Cow {
  id        String   @id // slug (ex: "mimosa")
  name      String
  breed     String
  age       Int
  farm      String
  weightKg  Int
  milkPct   Int // % de produção leiteira (0-100)
  mooLevel  Int // intensidade de mugido (0-10)
  distance  String // string lúdica: "2,3 anos-luz", "1 salto hiperespacial"
  hue       Int // matiz OKLCH (0-360) usado no placeholder da foto
  tags      String[]
  bio       String
  photoUrl  String?
  isHuman   Boolean            @default(false)
  createdAt DateTime           @default(now())

  // Proteção e matchmaking
  protectionLevel CowProtectionLevel @default(CAMPESTRE)
  desprevenida    Boolean            @default(false) // bypassa verificação de toalha
  personality     String? // "aventureira" | "tímida" | "travessa" | "pacífica"
  flightRisk      Int? // risco de fuga 0-10
  temperamento    String? // "dócil" | "rebelde" | "curiosa" | "indiferente"
  signoGalactico  String?
  papelNoRebanho  String? // "líder" | "isolada" | "popular" | "solitária"

  swipes     Swipe[]
  abductions Abduction[]
}

enum SwipeDirection {
  LIKE // abdução normal
  SUPER // abdução VIP (super-like)
  PASS // deixa pastar
}

model Swipe {
  id        String         @id @default(cuid())
  alienId   String
  cowId     String
  direction SwipeDirection
  createdAt DateTime       @default(now())

  alien User @relation(fields: [alienId], references: [id], onDelete: Cascade)
  cow   Cow  @relation(fields: [cowId], references: [id], onDelete: Cascade)

  @@unique([alienId, cowId])
  @@index([alienId])
  @@index([cowId])
}

enum AbductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ABORTED
}

model Abduction {
  id          String          @id @default(cuid())
  alienId     String
  cowId       String
  status      AbductionStatus @default(PLANNED)
  scheduledAt DateTime?
  notes       String?
  createdAt   DateTime        @default(now())

  alien User @relation(fields: [alienId], references: [id], onDelete: Cascade)
  cow   Cow  @relation(fields: [cowId], references: [id], onDelete: Cascade)

  @@unique([alienId, cowId])
}
